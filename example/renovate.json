{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "tools.lock"
      ],
      "matchStrings": [
        "(?<depName>[^\\s]+) (?<packageName>[^@]+)@(?<currentValue>v?[^\\s]+)"
      ],
      "versioningTemplate": "semver",
      "datasourceTemplate": "go"
    }
  ],
  "ignorePaths": []
}

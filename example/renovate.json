{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "tools.lock"
      ],
      "matchStrings": [
        "(?<depName>[^\\s]+) (?<currentValue>[^@]+@v?[^\\s]+)"
      ],
      "depNameTemplate": "go",
      "versioningTemplate": "semver"
    }
  ],
  "ignorePaths": []
}
